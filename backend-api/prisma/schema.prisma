generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password             String
  passwordResetToken   String?
  passwordResetExpires DateTime?
}

model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  image        String?
  parentId     String?
  deliveryInfo String?
  parent       Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryToCategory")
  products     Product[]
}

model Product {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  description  String?
  price        Float?
  weight       String?
  image        String?
  categoryId   String
  isBestSeller Boolean          @default(false)
  isNewLaunch  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  deliveryInfo String?
  isSoldOut    Boolean          @default(false)
  cartItems    CartItem[]
  heroBanners  HeroBanner[]
  orderItems   OrderItem[]
  category     Category         @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  variants     ProductVariant[]
  reviews      Review[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  weight    String
  price     Float
  stock     Int      @default(0)
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Branch {
  id           String  @id @default(cuid())
  name         String
  address      String
  city         String
  phone        String
  image        String?
  isHeadOffice Boolean @default(false)
  latitude     Float?
  longitude    Float?
}

model Announcement {
  id        String   @id @default(cuid())
  message   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroBanner {
  id            String    @id @default(cuid())
  image         String
  title         String?
  subtitle      String?
  ctaText       String    @default("SHOP NOW")
  linkType      String    @default("product")
  productId     String?
  categoryId    String?
  customUrl     String?
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  slideInterval Int       @default(6)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  product       Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id           String    @id @default(cuid())
  customerName String
  rating       Int
  comment      String
  createdAt    DateTime  @default(now())
  isVerified   Boolean   @default(false)
  productId    String
  status       String    @default("PENDING")
  updatedAt    DateTime  @updatedAt
  userId       String?
  adminReply   String?
  repliedAt    DateTime?
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model SiteSettings {
  id                   String   @id @default("default")
  deliveryPopupEnabled Boolean  @default(true)
  deliveryPopupTitle   String   @default("Delivery Notification!")
  deliveryPopupContent String   @default("• Chennai: Order before 3:00 PM for next-day delivery by 7PM.\n• Rest of India: Order before 3:00 PM for next-day dispatch.\n• Delivery Timeline: Rest of India: 2–4 days.")
  updatedAt            DateTime @updatedAt
  whatsappNumber       String   @default("919282445577")
  aboutPageContent     Json?
  contactPageContent   Json?
  privacy_content      String?
  terms_content        String?
  shipping_content     String?
  refund_content       String?
  splashContent        Json?
  dispatchCutoffHour   Int      @default(14)
  dispatchSundayPolicy Boolean  @default(false)
  dispatchLimitText    String   @default("ORDER WITHIN {time} HOURS")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password             String
  name                 String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  addressLine1  String?
  addressLine2  String?
  city          String?
  customerName  String?
  phoneNumber   String?
  pincode       String?
  state         String?
  fcmToken      String?
  isBanned      Boolean        @default(false)
  adminNotes    String?
  cartItems     CartItem[]
  notifications Notification[]
  orders        Order[]
  reviews       Review[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  weight    String
  quantity  Int      @default(1)
  variantId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  status                String      @default("PENDING")
  totalAmount           Float
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  couponCode            String?
  discountAmount        Float       @default(0)
  shippingCharge        Float       @default(0)
  addressLine1          String?
  addressLine2          String?
  city                  String?
  customerName          String?
  phoneNumber           String?
  pincode               String?
  razorpayOrderId       String?     @unique
  razorpayPaymentId     String?
  razorpaySignature     String?
  paymentStatus         String      @default("PENDING")
  deliveryManName       String?
  deliveryManPhone      String?
  trackingId            String?
  trackingLink          String?
  deliveredAt           DateTime?
  feedbackSentAt        DateTime?
  whatsappDeliveredSent Boolean     @default(false)
  whatsappFeedbackSent  Boolean     @default(false)
  whatsappOrderSent     Boolean     @default(false)
  whatsappShippedSent   Boolean     @default(false)
  user                  User        @relation(fields: [userId], references: [id])
  items                 OrderItem[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productName String   @default("Unknown Product")
  weight      String
  price       Float
  quantity    Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String    @default("FIXED")
  value         Float
  minCartAmount Float     @default(0)
  isActive      Boolean   @default(true)
  expiryDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ShippingRule {
  id                    String   @id @default(cuid())
  areaName              String   @unique
  pincodes              String?  @default("*")
  baseWeightLimit       Float    @default(1.0)
  baseCharge            Float
  additionalChargePerKg Float
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model CategoryPairing {
  id               String   @id @default(cuid())
  categoryId       String
  pairedCategoryId String
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([categoryId, pairedCategoryId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String?
  isAdmin   Boolean   @default(false)
  priority  String    @default("NORMAL") // LOW, NORMAL, HIGH
  type      String    @default("INFO")
  message   String
  orderId   String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BannedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model WhatsAppTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  message   String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
